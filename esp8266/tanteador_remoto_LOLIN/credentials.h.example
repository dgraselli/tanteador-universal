// Copiá este archivo a credentials.h y poné los valores reales:
//
//   cp credentials.h.example credentials.h
//
// credentials.h está en .gitignore. Nunca lo commitees.
// Generá contraseñas fuertes con:  openssl rand -base64 18
#pragma once

// Tiene que coincidir con SSID y AP_PASSWORD de secrets.env (el AP de la Pi).
#define WIFI_SSID     "TNT"
#define WIFI_PASSWORD "cambiame"

// Protege la actualización por WiFi. Sin esto, cualquiera conectado a la red
// TNT podría flashear el control remoto.
#define OTA_PASSWORD  "cambiame-tambien"
