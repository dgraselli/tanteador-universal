# Copiá este archivo a secrets.env y poné la contraseña real del AP:
#
#   cp secrets.env.example secrets.env
#   chmod 600 secrets.env
#
# secrets.env está en .gitignore. Nunca lo commitees.
# Generá una contraseña fuerte con:  openssl rand -base64 18
#
# WPA2 exige entre 8 y 63 caracteres ASCII imprimibles.
AP_PASSWORD="cambiame"
